# ==============================================================================
# .gitignore — Peer-Review (Referee) Workflow
# ==============================================================================

# Manuscripts under review are usually confidential — don't commit input PDFs.
# (Delete these two lines if you want to track example papers in the repo.)
papers/*.pdf
papers/*.PDF

# Referee pipeline scratch space (paper briefs, intermediates)
referee_reports/.work/

# Python
__pycache__/
*.pyc
*.pyo

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/
CLAUDE.local.md

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
